module ic_741(
    input real v_plus,
    input real v_minus,
    input real v_cc,
    input real v_ee,
    output real v_out
);

parameter real OPEN_LOOP_GAIN = 200000.0;
parameter real VDROP          = 1.5;
parameter real VOS            = 0.002;
parameter real SLEW_RATE      = 0.5;
parameter real ALPHA          = 0.05;

real v_diff;
real v_target;
real v_internal;
real max_output;
real min_output;
real delta;

initial begin
    v_internal = 0.0;
    v_out = 0.0;
end

always begin
    #1;

    v_diff = (v_plus - v_minus) + VOS;

    v_target = v_diff * OPEN_LOOP_GAIN;

    max_output = v_cc - VDROP;
    min_output = v_ee + VDROP;

    if(v_target > max_output)
        v_target = max_output;
    else if(v_target < min_output)
        v_target = min_output;

    v_internal = v_internal + ALPHA*(v_target - v_internal);

    delta = v_internal - v_out;

    if(delta > SLEW_RATE)
        v_out = v_out + SLEW_RATE;
    else if(delta < -SLEW_RATE)
        v_out = v_out - SLEW_RATE;
    else
        v_out = v_internal;
end

endmodule
