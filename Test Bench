module ic_741_tb;

    real v_plus;
    real v_minus;
    real v_cc;
    real v_ee;
    wire real v_out;

    real t;

    ic_741 uut(
        .v_plus(v_plus),
        .v_minus(v_minus),
        .v_cc(v_cc),
        .v_ee(v_ee),
        .v_out(v_out)
    );

    initial begin
        $dumpfile("ic741.vcd");
        $dumpvars(0, ic_741_tb);

        v_cc = 15.0;
        v_ee = -15.0;
        v_minus = 0.0;

        $monitor(
            "Time=%0t ns | Vin=%6.3fV | Vout=%6.3fV",
            $time,
            v_plus,
            v_out
        );
    end

    initial begin

        for(t = 0.0; t <= 10.0; t = t + 1.0) begin

            v_plus = 0.5*$sin(2.0*3.14159265*t/50.0);

            #1;
        end

        $finish;
    end

endmodule
